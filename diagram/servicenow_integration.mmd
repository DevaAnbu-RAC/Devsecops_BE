sequenceDiagram
    title ZDAD-58: ServiceNow Integration - Project & Ticket Sync

    participant ServiceNow
    participant Backend as Backend<br/>(src/routes/servicenow_sync_route.py)
    participant Database

    %% === Project Sync ===
    Note over ServiceNow,Database: Project Sync Flow

    ServiceNow->>Backend: POST /api/v1/sync/servicenow/projects<br/>{sn_project_id, project_name, onboarded_date, ...}
    Backend->>Backend: Decrypt token, extract ServiceNow email
    Backend->>Backend: Validate email against<br/>SERVICENOW_ALLOWED_EMAIL env var
    Backend->>Backend: Check servicenow_sync role
    Backend->>Backend: Validate payload (Pydantic schema)
    Backend->>Database: SELECT * FROM projects<br/>WHERE sn_project_id = request.sn_project_id
    alt Project already exists
        Database-->>Backend: Existing record found
        Backend->>Backend: Skip - no duplicate created
    else Project not found
        Database-->>Backend: No record
        Backend->>Database: SELECT status_id FROM statuses<br/>WHERE status_name = 'Inactive'
        Database-->>Backend: status_id
        Backend->>Database: INSERT INTO projects<br/>(project_id, sn_project_id, project_name,<br/>onboarded_date, status_id, is_active=1)
        Database-->>Backend: Project created
    end
    Backend-->>ServiceNow: 200 - Sync completed successfully

    %% === DevSecOps Tickets Sync ===
    Note over ServiceNow,Database: DevSecOps Tickets Sync Flow

    ServiceNow->>Backend: POST /api/v1/sync/servicenow/devsecops-tickets<br/>{tickets: [{sn_project_id, project_name,<br/>specialization_name, repositories, ...}]}
    Backend->>Backend: Decrypt token + validate ServiceNow email
    Backend->>Backend: Check servicenow_sync role
    Backend->>Backend: Validate payload (non-empty tickets array)

    loop For each ticket in batch
        Backend->>Database: SELECT specialization_id FROM specializations<br/>WHERE specialization_name = ticket.specialization_name
        alt Specialization not found
            Database-->>Backend: No record
            Backend->>Backend: Log WARNING, skip this ticket
        else Specialization found
            Database-->>Backend: specialization_id

            %% 3-step project resolution
            Backend->>Database: Step 1: SELECT project_id FROM projects<br/>WHERE sn_project_id = ticket.sn_project_id
            alt Matched by sn_project_id
                Database-->>Backend: project_id
            else Not found - try project_name
                Database-->>Backend: No record
                Backend->>Database: Step 2: SELECT project_id FROM projects<br/>WHERE project_name = ticket.project_name
                alt Matched by project_name
                    Database-->>Backend: project_id, sn_project_id
                else Not found - use default
                    Database-->>Backend: No record
                    Backend->>Database: Step 3: SELECT project_id FROM projects<br/>WHERE is default project
                    Database-->>Backend: default project_id
                end
            end

            Backend->>Database: INSERT INTO devsecops_tickets<br/>(ticket_id, specialization_id, project_id,<br/>sn_project_id, project_name, is_active=1)
            Database-->>Backend: Ticket created

            loop For each repository in ticket
                Backend->>Database: INSERT INTO repositories<br/>(repository_id, ticket_id, repository_name,<br/>ado_repo_id, is_active=1)
                Database-->>Backend: Repository created
            end
        end
    end

    Backend-->>ServiceNow: 200 - Sync completed successfully

    %% Error Scenario
    Note over Backend,Database: On unhandled exception
    Backend->>Database: INSERT INTO error_log<br/>(error_message, error_function, stack_trace)
    Backend-->>ServiceNow: 500 - Internal Server Error
